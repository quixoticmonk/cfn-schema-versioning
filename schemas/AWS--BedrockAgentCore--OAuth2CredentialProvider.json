          "description": "The client ID for the custom OAuth2 provider",
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "ClientSecret": {
          "description": "The client secret for the custom OAuth2 provider",
          "maxLength": 2048,
          "minLength": 1,
          "type": "string"
        },
        "OauthDiscovery": {
          "$ref": "#/definitions/Oauth2Discovery"
        }
      },
      "required": [
        "OauthDiscovery",
        "ClientId",
        "ClientSecret"
      ],
      "type": "object"
    },
