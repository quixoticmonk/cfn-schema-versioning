      ],
      "type": "object"
    },
    "GoogleOauth2ProviderConfigInput": {
      "additionalProperties": false,
      "description": "Input configuration for a Google OAuth2 provider",
      "properties": {
        "ClientId": {
          "maxLength": 256,
