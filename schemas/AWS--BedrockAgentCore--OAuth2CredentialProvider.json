      ],
      "type": "object"
    },
    "MicrosoftOauth2ProviderConfigInput": {
      "additionalProperties": false,
      "description": "Input configuration for a Microsoft OAuth2 provider",
      "properties": {
        "ClientId": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "ClientSecret": {
          "maxLength": 2048,
          "minLength": 1,
          "type": "string"
        },
        "TenantId": {
          "description": "The Microsoft Entra ID tenant ID",
          "maxLength": 2048,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "ClientId",
        "ClientSecret"
      ],
      "type": "object"
    },
    "Oauth2AuthorizationServerMetadata": {
      "additionalProperties": false,
      "description": "Authorization server metadata for the OAuth2 provider",
      "properties": {
        "AuthorizationEndpoint": {
          "description": "The authorization endpoint URL",
          "type": "string"
        },
        "Issuer": {
          "description": "The issuer URL for the OAuth2 authorization server",
          "type": "string"
        },
        "ResponseTypes": {
          "description": "The supported response types",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "TokenEndpoint": {
          "description": "The token endpoint URL",
          "type": "string"
        }
      },
      "required": [
        "Issuer",
        "AuthorizationEndpoint",
        "TokenEndpoint"
      ],
      "type": "object"
    },
    "Oauth2Discovery": {
      "additionalProperties": false,
      "description": "Discovery information for an OAuth2 provider",
      "properties": {
        "AuthorizationServerMetadata": {
          "$ref": "#/definitions/Oauth2AuthorizationServerMetadata"
        },
        "DiscoveryUrl": {
          "description": "The discovery URL for the OAuth2 provider",
          "pattern": "^.+/\\.well-known/openid-configuration$",
          "type": "string"
        }
      },
      "type": "object"
    },
    "Oauth2ProviderConfigInput": {
      "additionalProperties": false,
      "description": "Input configuration for an OAuth2 provider",
      "properties": {
        "AtlassianOauth2ProviderConfig": {
          "$ref": "#/definitions/AtlassianOauth2ProviderConfigInput"
        },
        "CustomOauth2ProviderConfig": {
          "$ref": "#/definitions/CustomOauth2ProviderConfigInput"
        },
        "GithubOauth2ProviderConfig": {
          "$ref": "#/definitions/GithubOauth2ProviderConfigInput"
        },
