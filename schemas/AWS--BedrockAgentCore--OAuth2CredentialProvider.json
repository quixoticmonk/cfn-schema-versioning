{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/Name",
    "/properties/CredentialProviderVendor"
  ],
  "definitions": {
    "AtlassianOauth2ProviderConfigInput": {
      "additionalProperties": false,
      "description": "Input configuration for an Atlassian OAuth2 provider",
      "properties": {
        "ClientId": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "ClientSecret": {
          "maxLength": 2048,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "ClientId",
        "ClientSecret"
      ],
      "type": "object"
    },
    "ClientSecretArn": {
      "additionalProperties": false,
      "description": "Contains information about a secret in AWS Secrets Manager",
      "properties": {
        "SecretArn": {
          "description": "The ARN of the secret in AWS Secrets Manager",
          "pattern": "^arn:(aws|aws-us-gov):secretsmanager:[A-Za-z0-9-]{1,64}:[0-9]{12}:secret:[a-zA-Z0-9-_/+=.@!]+$",
          "type": "string"
        }
      },
      "required": [
        "SecretArn"
      ],
      "type": "object"
    },
    "CustomOauth2ProviderConfigInput": {
      "additionalProperties": false,
