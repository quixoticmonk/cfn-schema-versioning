        },
        "ClientSecret": {
          "maxLength": 2048,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "ClientId",
        "ClientSecret"
      ],
      "type": "object"
    },
    "Tag": {
      "additionalProperties": false,
      "properties": {
        "Key": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$",
          "type": "string"
        },
        "Value": {
          "maxLength": 256,
          "minLength": 0,
          "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$",
          "type": "string"
        }
      },
      "required": [
        "Key",
        "Value"
      ],
      "type": "object"
    }
  },
  "description": "Resource Type definition for AWS::BedrockAgentCore::OAuth2CredentialProvider",
  "handlers": {
    "create": {
      "permissions": [
        "bedrock-agentcore:CreateOauth2CredentialProvider",
        "bedrock-agentcore:GetOauth2CredentialProvider",
        "bedrock-agentcore:CreateTokenVault",
        "bedrock-agentcore:TagResource",
        "secretsmanager:CreateSecret"
      ]
    },
    "delete": {
      "permissions": [
        "bedrock-agentcore:DeleteOauth2CredentialProvider",
        "bedrock-agentcore:GetOauth2CredentialProvider",
        "secretsmanager:DeleteSecret"
      ]
    },
    "list": {
      "permissions": [
        "bedrock-agentcore:ListOauth2CredentialProviders"
      ]
    },
    "read": {
      "permissions": [
        "bedrock-agentcore:GetOauth2CredentialProvider",
        "bedrock-agentcore:ListTagsForResource"
      ]
    },
    "update": {
      "permissions": [
        "bedrock-agentcore:UpdateOauth2CredentialProvider",
        "bedrock-agentcore:GetOauth2CredentialProvider",
        "bedrock-agentcore:TagResource",
        "bedrock-agentcore:UntagResource",
        "bedrock-agentcore:ListTagsForResource",
        "secretsmanager:PutSecretValue"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/CredentialProviderArn"
  ],
  "properties": {
    "CallbackUrl": {
      "description": "The callback URL for the OAuth2 authorization flow",
      "type": "string"
    },
    "ClientSecretArn": {
      "$ref": "#/definitions/ClientSecretArn",
      "description": "The ARN of the client secret in AWS Secrets Manager"
    },
    "CreatedTime": {
      "description": "The timestamp when the credential provider was created",
      "format": "date-time",
      "type": "string"
    },
    "CredentialProviderArn": {
      "description": "The Amazon Resource Name (ARN) of the OAuth2 credential provider",
      "pattern": "^arn:(aws|aws-us-gov):bedrock-agentcore:[A-Za-z0-9-]{1,64}:[0-9]{12}:token-vault/[a-zA-Z0-9-.]+/oauth2credentialprovider/[a-zA-Z0-9-]+$",
      "type": "string"
    },
    "CredentialProviderVendor": {
      "description": "The vendor of the OAuth2 credential provider",
      "enum": [
        "GoogleOauth2",
        "GithubOauth2",
        "SlackOauth2",
        "SalesforceOauth2",
        "MicrosoftOauth2",
        "CustomOauth2",
        "AtlassianOauth2",
        "LinkedinOauth2",
        "XOauth2",
        "OktaOauth2",
        "OneLoginOauth2",
        "PingOneOauth2",
        "FacebookOauth2",
        "YandexOauth2",
        "RedditOauth2",
        "ZoomOauth2",
        "TwitchOauth2",
        "SpotifyOauth2",
        "DropboxOauth2",
        "NotionOauth2",
        "HubspotOauth2",
        "CyberArkOauth2",
        "FusionAuthOauth2",
        "Auth0Oauth2",
        "CognitoOauth2"
      ],
      "type": "string"
    },
    "LastUpdatedTime": {
      "description": "The timestamp when the credential provider was last updated",
      "format": "date-time",
      "type": "string"
    },
    "Name": {
      "description": "The name of the OAuth2 credential provider",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9\\-_]+$",
      "type": "string"
    },
    "Oauth2ProviderConfigInput": {
      "$ref": "#/definitions/Oauth2ProviderConfigInput",
      "description": "The configuration settings for the OAuth2 provider"
    },
    "Oauth2ProviderConfigOutput": {
      "$ref": "#/definitions/Oauth2ProviderConfigOutput",
      "description": "The output configuration for the OAuth2 provider"
    },
    "Tags": {
      "description": "Tags to assign to the OAuth2 credential provider",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "maxItems": 50,
      "type": "array"
    }
  },
  "readOnlyProperties": [
    "/properties/CredentialProviderArn",
    "/properties/ClientSecretArn",
    "/properties/CallbackUrl",
    "/properties/Oauth2ProviderConfigOutput",
    "/properties/CreatedTime",
    "/properties/LastUpdatedTime"
  ],
  "required": [
    "Name",
    "CredentialProviderVendor"
  ],
  "tagging": {
    "cloudFormationSystemTags": true,
    "permissions": [
      "bedrock-agentcore:TagResource",
      "bedrock-agentcore:UntagResource",
      "bedrock-agentcore:ListTagsForResource"
    ],
    "tagOnCreate": true,
    "tagProperty": "/properties/Tags",
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "AWS::BedrockAgentCore::OAuth2CredentialProvider",
  "writeOnlyProperties": [
    "/properties/Oauth2ProviderConfigInput"
  ]
}