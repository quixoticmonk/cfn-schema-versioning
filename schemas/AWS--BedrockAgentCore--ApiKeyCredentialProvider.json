      ]
    },
    "read": {
      "permissions": [
        "bedrock-agentcore:GetApiKeyCredentialProvider",
        "bedrock-agentcore:ListTagsForResource"
      ]
    },
    "update": {
      "permissions": [
        "bedrock-agentcore:UpdateApiKeyCredentialProvider",
        "bedrock-agentcore:GetApiKeyCredentialProvider",
        "bedrock-agentcore:TagResource",
