    "tagOnCreate": true,
    "tagProperty": "/properties/Tags",
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "AWS::BedrockAgentCore::ApiKeyCredentialProvider",
  "writeOnlyProperties": [
